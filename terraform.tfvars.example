location             = "eastus"
project              = "bci"
environment          = "infra"

rg_infra_name        = "rg-bci-infra"
rg_app_name          = "rg-bci-app"

aks_cluster_name     = "aks-bci-infra"
aks_node_count       = 1
aks_node_size        = "Standard_D2s_v3"
kubernetes_version   = "1.28"

postgres_server_name    = "psql-bci-vault"
