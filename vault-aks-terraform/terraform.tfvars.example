# terraform.tfvars
# ⚠️ NO subir a git — agregar al .gitignore

location           = "eastus"
project            = "bci"
environment        = "infra"

rg_infra_name      = "rg-bci-infra"
rg_app_name        = "rg-bci-app"

aks_cluster_name   = "aks-bci-infra"
aks_node_count     = 1
aks_node_size      = "Standard_D2s_v3"
kubernetes_version = "1.35.3"

postgres_admin_user     = "vaultadmin"
postgres_admin_password = "CAMBIA_ESTO_POR_UNA_PASSWORD_SEGURA"
postgres_db_name        = "vault"

vault_namespace    = "bci-infra"
vault_release_name = "vault"
